{
  "rewrites": [
    { "source": "/api/list-sync-runs", "destination": "/api/persist-sync-run" },
    { "source": "/api/list-upload-versions", "destination": "/api/list-uploads?mode=versions" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/reminders?slot=auto&schedule=sunday",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/reminders?slot=auto&schedule=wednesday",
      "schedule": "0 10 * * 3"
    }
  ],
  "functions": {
    "api/sync.ts": {
      "maxDuration": 120
    },
    "api/reminders.ts": {
      "maxDuration": 120,
      "includeFiles": "api/_lib/**"
    },
    "api/reminder-status.ts": {
      "maxDuration": 60,
      "includeFiles": "api/_lib/**"
    },
    "api/list-uploads.ts": {
      "includeFiles": "api/_lib/**"
    },
    "api/student-engagement.ts": {
      "includeFiles": "api/_lib/**"
    }
  }
}
