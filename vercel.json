{
  "rewrites": [
    { "source": "/api/list-sync-runs", "destination": "/api/persist-sync-run" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/reminders",
      "schedule": "0 4,13 * * 0"
    }
  ],
  "functions": {
    "api/sync.ts": {
      "maxDuration": 120
    },
    "api/reminders.ts": {
      "maxDuration": 120
    }
  }
}
